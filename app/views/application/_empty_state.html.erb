<%# Reusable empty state. locals: message (string), icon (optional html), action (optional html link/button) %>
<div class="rounded-xl border border-dashed border-slate-300 bg-white px-6 py-14 text-center shadow-card">
  <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-slate-100 text-slate-400">
    <%= local_assigns[:icon] || raw('<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>') %>
  </div>
  <p class="mt-4 text-sm text-slate-500"><%= local_assigns[:message] || "Nothing here yet." %></p>
  <% if local_assigns[:action] %>
    <div class="mt-5"><%= action %></div>
  <% end %>
</div>
