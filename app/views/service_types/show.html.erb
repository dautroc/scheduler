<%= render "application/page_header",
      title: @service_type.name,
      actions: link_to("← Service types", service_types_path,
            class: "inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3.5 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50") %>

<div class="rounded-xl border border-slate-200 bg-white p-6 shadow-card">
  <div class="flex items-center gap-4">
    <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
    </span>
    <div>
      <p class="text-sm text-slate-500">Duration</p>
      <p class="text-xl font-semibold text-slate-900"><%= @service_type.duration_minutes %> minutes</p>
    </div>
  </div>
</div>

<div class="rounded-xl border border-slate-200 bg-white p-6 shadow-card">
  <h2 class="flex items-center gap-2 text-base font-semibold text-slate-900">
    <svg class="h-5 w-5 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a7 7 0 0 1 14 0v1"/></svg>
    Qualified technicians
    <span class="ml-1 rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500"><%= @service_type.technicians.size %></span>
  </h2>
  <% if @service_type.technicians.any? %>
    <ul class="mt-4 space-y-3">
      <% @service_type.technicians.each do |t| %>
        <li class="flex items-center gap-3">
          <span class="flex h-9 w-9 flex-none items-center justify-center rounded-full text-xs font-semibold text-white <%= avatar_color(t.name) %>"><%= initials(t.name) %></span>
          <div>
            <p class="font-medium text-slate-900"><%= t.name %></p>
            <p class="text-xs text-slate-400"><%= t.dealership.name %></p>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-3 text-sm text-slate-400">No technicians are qualified for this service yet.</p>
  <% end %>
</div>
