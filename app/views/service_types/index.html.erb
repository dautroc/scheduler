<%= render "application/page_header",
      title: "Service Types",
      subtitle: "Each service has a fixed duration that defines the appointment window." %>

<% if @service_types.any? %>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% @service_types.each do |st| %>
      <%= link_to service_type_path(st), class: "group block rounded-xl border border-slate-200 bg-white p-5 shadow-card transition-all hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-card-lg" do %>
        <div class="flex items-center justify-between">
          <h3 class="font-semibold text-slate-900 group-hover:text-brand-700"><%= st.name %></h3>
          <svg class="h-4 w-4 text-slate-300 group-hover:text-brand-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg>
        </div>
        <div class="mt-4 flex items-center gap-4 text-sm">
          <span class="inline-flex items-center gap-1.5 text-slate-600">
            <svg class="h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <span class="font-medium"><%= st.duration_minutes %></span> min
          </span>
          <span class="inline-flex items-center gap-1.5 text-slate-600">
            <svg class="h-4 w-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zM3 16a4 4 0 014-4h6a4 4 0 014 4v1H3v-1z"/></svg>
            <span class="font-medium"><%= st.technicians.count %></span> qualified
          </span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "application/empty_state", message: "No service types configured." %>
<% end %>
