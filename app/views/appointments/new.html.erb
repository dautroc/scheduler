<%= render "application/page_header",
      title: "Book an Appointment",
      subtitle: "Pick a dealership, service, and time, then check availability against free bays and qualified technicians." %>

<%# Availability banner shown when returning from check_availability %>
<% if @availability %>
  <% if @availability[:available] %>
    <div class="flex items-start gap-3 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3.5 text-sm text-emerald-800 shadow-sm">
      <svg class="mt-0.5 h-5 w-5 flex-none text-emerald-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
      <div>
        <p class="font-medium">Available — <%= @availability[:free_bays] %> free bay(s) and <%= @availability[:free_technicians] %> qualified technician(s).</p>
        <p class="text-emerald-700/80"><%= @availability[:starts_at]&.strftime("%b %-d, %H:%M") %>–<%= @availability[:ends_at]&.strftime("%H:%M") %></p>
      </div>
    </div>
  <% else %>
    <div class="flex items-start gap-3 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3.5 text-sm text-rose-800 shadow-sm">
      <svg class="mt-0.5 h-5 w-5 flex-none text-rose-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
      <p class="font-medium"><%= @availability[:reason] %></p>
    </div>
  <% end %>
<% end %>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <%# --- Availability check form --- %>
  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-card">
    <h2 class="flex items-center gap-2 text-base font-semibold text-slate-900">
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">1</span>
      Find a slot
    </h2>
    <%= form_with url: check_availability_appointments_path, method: :get, local: true, id: "availability-form", class: "mt-5 space-y-4" do |f| %>
      <div>
        <%= f.label :dealership_id, "Dealership", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :dealership_id,
              options_from_collection_for_select(@dealerships, :id, :name, @selected&.dig(:dealership_id)),
              { prompt: "Select a dealership…" },
              class: "mt-1.5 block w-full rounded-lg border-slate-300 bg-white py-2 pl-3 pr-8 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" %>
      </div>
      <div>
        <%= f.label :service_type_id, "Service type", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :service_type_id,
              options_from_collection_for_select(@service_types, :id, ->(st) { "#{st.name} (#{st.duration_minutes} min)" }, @selected&.dig(:service_type_id)),
              { prompt: "Select a service…" },
              class: "mt-1.5 block w-full rounded-lg border-slate-300 bg-white py-2 pl-3 pr-8 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" %>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <%= f.label :starts_at_date, "Date", class: "block text-sm font-medium text-slate-700" %>
          <%= f.date_field :starts_at_date, value: @selected&.dig(:starts_at_date) || Date.tomorrow,
                class: "mt-1.5 block w-full rounded-lg border-slate-300 bg-white py-2 pl-3 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" %>
        </div>
        <div>
          <%= f.label :starts_at_time, "Time", class: "block text-sm font-medium text-slate-700" %>
          <%= f.time_field :starts_at_time, value: @selected&.dig(:starts_at_time) || "09:00",
                class: "mt-1.5 block w-full rounded-lg border-slate-300 bg-white py-2 pl-3 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" %>
        </div>
      </div>
      <%= f.submit "Check availability", name: nil,
            class: "inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50" %>
    <% end %>
  </div>

  <%# --- Confirm booking form --- %>
  <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-card">
    <h2 class="flex items-center gap-2 text-base font-semibold text-slate-900">
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">2</span>
      Confirm booking
    </h2>
    <%= form_with url: appointments_path, local: true, class: "mt-5 space-y-4" do |f| %>
      <div>
        <%= f.label :customer_id, "Customer", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :customer_id,
              options_from_collection_for_select(@customers, :id, ->(c) { "#{c.name} (#{c.email})" }, @selected&.dig(:customer_id)),
              { prompt: "Select a customer…" },
              id: "customer-select",
              class: "mt-1.5 block w-full rounded-lg border-slate-300 bg-white py-2 pl-3 pr-8 text-sm text-slate-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" %>
        <p class="mt-1.5 text-xs text-slate-400">Don't see the customer? <%= link_to "Add one", new_customer_path, class: "font-medium text-brand-700 hover:underline" %>.</p>
      </div>
      <div>
        <%= f.label :vehicle_id, "Vehicle", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :vehicle_id, [], { prompt: "Select a customer first…" },
              id: "vehicle-select", disabled: true,
              class: "mt-1.5 block w-full rounded-lg border-slate-300 bg-slate-50 py-2 pl-3 pr-8 text-sm text-slate-500 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30 disabled:bg-slate-50" %>
      </div>

      <%# Carry selections from the availability form into the booking submit %>
      <%= f.hidden_field :dealership_id,   value: @selected&.dig(:dealership_id) %>
      <%= f.hidden_field :service_type_id, value: @selected&.dig(:service_type_id) %>
      <%= f.hidden_field :starts_at_date,  value: @selected&.dig(:starts_at_date) %>
      <%= f.hidden_field :starts_at_time,  value: @selected&.dig(:starts_at_time) %>

      <%= f.submit "Confirm appointment",
            class: "inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700" %>
    <% end %>
  </div>
</div>

<script>
  // Load vehicles for the selected customer via JSON and populate the vehicle select.
  (function () {
    var customerSelect = document.getElementById("customer-select");
    var vehicleSelect  = document.getElementById("vehicle-select");
    if (!customerSelect || !vehicleSelect) return;

    function loadVehicles(customerId, keepId) {
      vehicleSelect.innerHTML = "";
      if (!customerId) {
        vehicleSelect.disabled = true;
        vehicleSelect.add(new Option("Select a customer first…", "", true, true));
        return;
      }
      vehicleSelect.add(new Option("Loading…", "", true, true));
      fetch("<%= customers_path %>/" + customerId + "/vehicles.json")
        .then(function (r) { return r.json(); })
        .then(function (vehicles) {
          vehicleSelect.innerHTML = "";
          if (vehicles.length === 0) {
            vehicleSelect.add(new Option("No vehicles — add one on the customer page", "", true, true));
            vehicleSelect.disabled = true;
            return;
          }
          vehicleSelect.add(new Option("Select a vehicle…", "", true, true));
          vehicles.forEach(function (v) {
            var label = v.year + " " + v.make + " " + v.model + (v.vin ? " (" + v.vin + ")" : "");
            var opt = new Option(label, v.id);
            if (keepId && String(v.id) === String(keepId)) opt.selected = true;
            vehicleSelect.add(opt);
          });
          vehicleSelect.disabled = false;
        });
    }

    customerSelect.addEventListener("change", function () {
      loadVehicles(customerSelect.value, "<%= @selected&.dig(:vehicle_id) %>");
    });

    if (customerSelect.value) loadVehicles(customerSelect.value, "<%= @selected&.dig(:vehicle_id) %>");
  })();
</script>
